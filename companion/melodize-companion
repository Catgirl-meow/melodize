#!/usr/bin/env python3
"""
melodize-companion  —  Navidrome file-management sidecar for Melodize.

Endpoints
---------
GET  /health                   liveness probe
DELETE /api/songs/{id}         delete a song from disk by Navidrome ID
POST /api/songs/download       download a song from a URL (requires yt-dlp)
GET  /api/songs/download/{id}  check download job status

Auth: X-API-Key header.
Config: /etc/melodize-companion/config.json
"""

import hashlib, http.server, json, logging, os, pathlib, re
import sqlite3, subprocess, sys, threading, time, urllib.parse, urllib.request
from typing import Optional

# ---------------------------------------------------------------------------
CONFIG_PATH = "/etc/melodize-companion/config.json"

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s  %(levelname)-7s  %(message)s",
    handlers=[logging.StreamHandler(sys.stdout)],
)
log = logging.getLogger("melodize-companion")


def load_config() -> dict:
    with open(CONFIG_PATH) as f:
        cfg = json.load(f)
    required = ("api_key", "music_dir", "navidrome_db")
    for k in required:
        if not cfg.get(k):
            sys.exit(f"Config missing required key: {k}")
    return cfg


# ---------------------------------------------------------------------------
# Background download job registry

_jobs: dict[str, dict] = {}   # job_id -> {status, url, error, path}
_jobs_lock = threading.Lock()


def _new_job(job_id: str, url: str) -> None:
    with _jobs_lock:
        _jobs[job_id] = {"status": "queued", "url": url, "error": None, "path": None}


def _update_job(job_id: str, **kwargs) -> None:
    with _jobs_lock:
        _jobs[job_id].update(kwargs)


def _run_download(job_id: str, url: str, cfg: dict) -> None:
    _update_job(job_id, status="downloading")
    music_dir = cfg["music_dir"]
    ytdlp = cfg.get("ytdlp_path", "yt-dlp")
    # Output template: Artist - Title.ext  (same flat layout as existing files)
    output_tmpl = os.path.join(music_dir, "%(uploader)s - %(title)s.%(ext)s")
    try:
        result = subprocess.run(
            [
                ytdlp,
                "--extract-audio",
                "--audio-format", cfg.get("download_format", "flac"),
                "--audio-quality", "0",
                "--output", output_tmpl,
                "--no-playlist",
                "--no-progress",
                url,
            ],
            capture_output=True, text=True, timeout=600,
        )
        if result.returncode != 0:
            _update_job(job_id, status="error", error=result.stderr[-800:])
            log.error(f"[job {job_id}] yt-dlp failed: {result.stderr[-200:]}")
        else:
            _update_job(job_id, status="done")
            log.info(f"[job {job_id}] download complete")
    except subprocess.TimeoutExpired:
        _update_job(job_id, status="error", error="download timed out after 600s")
    except FileNotFoundError:
        _update_job(job_id, status="error", error="yt-dlp not installed on server")
    except Exception as e:
        _update_job(job_id, status="error", error=str(e))


# ---------------------------------------------------------------------------

class _Handler(http.server.BaseHTTPRequestHandler):
    """Single threaded for now — DB writes are serialised by the GIL anyway."""

    # Silence default access log; we use our own
    def log_message(self, fmt, *args):
        log.info(f"{self.address_string()} \"{fmt % args}\"")

    def log_error(self, fmt, *args):
        log.warning(f"{self.address_string()} \"{fmt % args}\"")

    # --- helpers ---

    def _send(self, code: int, body: dict) -> None:
        data = json.dumps(body).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def _auth(self) -> bool:
        key = self.headers.get("X-API-Key", "")
        if key != self.server.cfg["api_key"]:
            self._send(403, {"error": "invalid or missing API key"})
            return False
        return True

    def _body(self) -> dict:
        n = int(self.headers.get("Content-Length", 0))
        return json.loads(self.rfile.read(n)) if n > 0 else {}

    def _lookup_path(self, song_id: str) -> Optional[str]:
        """Return relative path (filename) for a Navidrome song ID, or None."""
        conn = sqlite3.connect(self.server.cfg["navidrome_db"], check_same_thread=False)
        try:
            cur = conn.execute("SELECT path FROM media_file WHERE id = ?", (song_id,))
            row = cur.fetchone()
            return row[0] if row else None
        finally:
            conn.close()

    # --- routing ---

    def do_GET(self):
        p = self.path.split("?")[0]
        if p == "/health":
            self._send(200, {"status": "ok", "version": "1.1.0"})
            return

        m = re.match(r"^/api/songs/download/([A-Za-z0-9_-]+)$", p)
        if m:
            if not self._auth():
                return
            jid = m.group(1)
            with _jobs_lock:
                job = _jobs.get(jid)
            if not job:
                self._send(404, {"error": "job not found"})
            else:
                self._send(200, job)
            return

        self._send(404, {"error": "not found"})

    def do_DELETE(self):
        if not self._auth():
            return
        m = re.match(r"^/api/songs/([^/?]+)$", self.path.split("?")[0])
        if not m:
            self._send(404, {"error": "not found"})
            return
        song_id = m.group(1)
        cfg = self.server.cfg

        try:
            rel = self._lookup_path(song_id)
            if rel is None:
                self._send(404, {"error": "song not found in database"})
                return

            full = pathlib.Path(cfg["music_dir"]) / rel
            if not full.exists():
                # Already gone — treat as success
                log.warning(f"File already missing: {full}")
                self._send(200, {"ok": True, "note": "file was already absent"})
                return

            full.unlink()
            log.info(f"Deleted: {full}")
            self._send(200, {"ok": True})

        except Exception as e:
            log.exception("Unexpected error during delete")
            self._send(500, {"error": str(e)})

    def do_POST(self):
        if not self._auth():
            return
        p = self.path.split("?")[0]

        if p == "/api/songs/download":
            self._handle_download_start()
        else:
            self._send(404, {"error": "not found"})

    def _handle_download_start(self):
        try:
            body = self._body()
        except (json.JSONDecodeError, ValueError):
            self._send(400, {"error": "invalid JSON body"})
            return

        url = (body.get("url") or "").strip()
        if not url:
            self._send(400, {"error": "'url' is required"})
            return

        import secrets
        job_id = secrets.token_urlsafe(12)
        _new_job(job_id, url)
        t = threading.Thread(
            target=_run_download, args=(job_id, url, self.server.cfg), daemon=True
        )
        t.start()
        self._send(202, {"job_id": job_id, "status": "queued"})


# ---------------------------------------------------------------------------

class _Server(http.server.HTTPServer):
    def __init__(self, addr, handler, cfg):
        self.cfg = cfg
        super().__init__(addr, handler)


def main():
    cfg = load_config()
    port = int(cfg.get("port", 8765))
    srv = _Server(("0.0.0.0", port), _Handler, cfg)
    log.info(f"melodize-companion v1.1 — listening on 0.0.0.0:{port}")
    log.info(f"  music_dir:     {cfg['music_dir']}")
    log.info(f"  navidrome_db:  {cfg['navidrome_db']}")
    try:
        srv.serve_forever()
    except KeyboardInterrupt:
        log.info("Shutting down")


if __name__ == "__main__":
    main()
